APP_NAME="Argus Demo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://argus.dev.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Postgres is the Argus default store. Host names match the compose service names.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=argus
DB_USERNAME=argus
DB_PASSWORD=argus

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Horizon processes the demo queue off Valkey; Argus buffers transitions there too.
QUEUE_CONNECTION=redis
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=valkey
REDIS_PASSWORD=valkey
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@argus.test"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Argus (codysseydev/argus) core
# ---------------------------------------------------------------------------
ARGUS_STORE=postgres
ARGUS_PG_CONNECTION=pgsql
ARGUS_BUFFER=redis
ARGUS_REDIS_CONNECTION=default
ARGUS_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Argus API (codysseydev/argus-api)
# ---------------------------------------------------------------------------
# Authorize the JSON API off the standard web session guard. The SPA is served
# same-origin (https://argus.dev.test/argus), so a logged-in session authorizes
# every /argus-api request via its cookie + X-XSRF-TOKEN.
ARGUS_API_GUARD=web
